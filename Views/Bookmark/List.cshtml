@model IEnumerable<BOOKMARK.Models.Bookmark>
@if (TempData["Message"] != null)
{
    <div style="color: green; font-weight: bold;">
        @TempData["Message"]
    </div>
}

<h2>Your Bookmarks</h2>
<form asp-action="List" method="get">
    <input type="text" name="search" value="@ViewBag.Search" placeholder="Search by Title or URL" />
    <button type="submit">Search</button>
</form>
<div>
    @if (ViewBag.Page > 1)
    {
        <a href="@Url.Action("List", new { page = ViewBag.Page - 1, search = ViewBag.Search })">Previous</a>
    }

    Page @ViewBag.Page of @ViewBag.TotalPages

    @if (ViewBag.Page < ViewBag.TotalPages)
    {
        <a href="@Url.Action("List", new { page = ViewBag.Page + 1, search = ViewBag.Search })">Next</a>
    }
</div>

<table>
    <tr>
        <th>Title</th>
        <th>URL</th>
    </tr>
    @foreach (var b in Model)
    {
        <tr>
            <td>@b.Title</td>
            <td><a href="@b.Url" target="_blank">@b.Url</a></td>
            <td>@b.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            <td>
                <a asp-controller="Bookmark" asp-action="Edit" asp-route-id="@b.Id">Edit</a> |
                <form asp-controller="Bookmark" asp-action="Delete" asp-route-id="@b.Id" method="post" style="display:inline;">
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete</button>
                </form>
            </td>
            <td>
                <form asp-action="Delete" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@b.Id" />
                    <button type="submit" style="color:red">Delete</button>
                </form>
            </td>

        </tr>
    }
</table>
<!-- FIX: Pagination buttons -->
<div>
    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="List" asp-route-page="@(ViewBag.CurrentPage - 1)">Previous</a>
    }

    Page @ViewBag.CurrentPage of @ViewBag.TotalPages

    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="List" asp-route-page="@(ViewBag.CurrentPage + 1)">Next</a>
    }
</div>